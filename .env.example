# Path to your local models directory (will be mounted as /models inside containers)
MODELS_DIR=/path/to/your/models

# Path to your custom RS-LLaVA repository (if you have custom changes to LLaVA)
# This will be mounted as /app/RS-LLaVA inside the rsllava container
RSLLAVA_DIR=/path/to/RS-LLaVA

# Web interface port
WEB_PORT=8000
